{
  "workbench.iconTheme": "material-icon-theme",
  "extensions.autoUpdate": false,
  "settingsSync.ignoredSettings": [],
  "window.menuBarVisibility": "toggle",
  "window.commandCenter": false,
  "workbench.layoutControl.enabled": false,
  "editor.cursorBlinking": "expand",
  "editor.minimap.size": "fit",
  "extensions.ignoreRecommendations": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "terminal.external.linuxExec": "warp",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "rust": false,
    "cpp": false,
    "go": false
  },
  "editor.fontFamily": "Fira Code",
  "editor.fontLigatures": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": false,
  "editor.linkedEditing": true,
  "window.zoomLevel": 0.9,
  "editor.wordWrap": "on",
  "explorer.compactFolders": false,
  "editor.guides.bracketPairs": true,
  "editor.mouseWheelZoom": true,
  "errorLens.gutterIconsEnabled": false,
  "errorLens.statusBarColorsEnabled": true,
  "errorLens.statusBarMessageEnabled": true,
  "errorLens.statusBarMessageType": "closestSeverity",
  "errorLens.followCursor": "closestProblem",
  "errorLens.scrollbarHackEnabled": true,
  "errorLens.fontStyleItalic": true,
  "errorLens.messageBackgroundMode": "message",
  "workbench.colorCustomizations": {
    "editorInfo.foreground": "#0080ff6a"
  },
  "svg.preview.mode": "svg",
  "[svg]": {
    "editor.defaultFormatter": "jock.svg"
  },
  "editor.cursorSmoothCaretAnimation": "on",
  "terminal.integrated.fontFamily": "RecMonoCasual Nerd Font Mono",
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.inlayHints.enabled": "offUnlessPressed"
  },
  "errorLens.excludeBySource": ["C/C++(520)"],
  "liveServer.settings.donotShowInfoMsg": true,
  "terminal.integrated.profiles.linux": {
    "bash": {
      "path": "bash",
      "icon": "terminal-bash"
    },
    "zsh": {
      "path": "zsh"
    },
    "fish": {
      "path": "fish"
    },
    "tmux": {
      "path": "tmux",
      "icon": "terminal-tmux"
    },
    "pwsh": {
      "path": "pwsh",
      "icon": "terminal-powershell"
    },
    "nu": {
      "path": "/bin/nu"
    }
  },
  "terminal.integrated.defaultProfile.linux": "zsh",
  "github.copilot.editor.enableAutoCompletions": true,
  "supermaven.enable": {
    "rust": false,
    "*": true,
    "cpp": false,
    "java": false,
    "go": false
  },
  "editor.minimap.enabled": false,
  "editor.tokenColorCustomizations": {
    "[Astro Kanagawa Dark]": {
      "comments": {
        "foreground": "#FF9E3B"
      }
    },
    "[Catppuccin Mocha]": {
      "comments": {
        "foreground": "#a6adc8"
      }
    }
  },
  "editor.semanticHighlighting.enabled": true,
  "terminal.integrated.minimumContrastRatio": 1,
  "window.titleBarStyle": "custom",
  "gopls": {
    "ui.semanticTokens": true
  },
  "supermaven.otherWarning": false,
  "[go]": {
    "editor.defaultFormatter": "golang.go"
  },
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "window.customTitleBarVisibility": "auto",
  "workbench.colorTheme": "One Dark Pro",
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  },
  "typescript.updateImportsOnFileMove.enabled": "always",
  "git.openRepositoryInParentFolders": "never"
}
